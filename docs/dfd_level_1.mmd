flowchart TD
    %% Level 1 Data Flow Diagram
    %% External Entities
    E_EMP[Employee]
    E_HR[HR Manager]

    %% Processes
    P1((1.0 Identity & Access Mgmt))
    P2((2.0 HR & Time Tracking))
    P3((3.0 Payroll & Finance))
    P4((4.0 Performance Mgmt))

    %% Data Stores
    D1[(D1: User & Tenant DB)]
    D2[(D2: HR DB)]
    D3[(D3: Payroll & EventStore DB)]
    D4[(D4: Performance DB)]

    %% Data Flows to/from Entities
    E_EMP -->|Login Credentials| P1
    P1 -->|Auth Token| E_EMP
    
    E_EMP -->|Clock In/Out, Leave Req| P2
    P2 -->|Status Updates| E_EMP
    E_HR -->|Approvals, Shift Schedules| P2
    
    E_EMP -->|Tax Info| P3
    P3 -->|Payslips| E_EMP
    E_HR -->|Trigger Payroll Batch| P3

    E_HR -->|Assign OKRs| P4
    E_EMP -->|Submit Reviews| P4
    P4 -->|Feedback Scores| E_EMP

    %% Data Flows to/from Stores
    P1 -->|Read/Write Auth| D1
    P2 -->|Verify User| D1
    P2 -->|Log Time/Leave| D2
    P3 -->|Get Attendance| D2
    P3 -->|Get User Base Pay| D1
    P3 -->|Store Payslips & Ledger| D3
    P4 -->|Store Reviews| D4
    P4 -->|Get User Info| D1
