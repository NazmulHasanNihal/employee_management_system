    style ALERT fill:#fff1f2,stroke:#e11d48,stroke-width:2px
    style REPLAY fill:#ecfdf5,stroke:#059669,stroke-width:2px
    style RESTORE fill:#ecfdf5,stroke:#059669,stroke-width:2px
    style POSTMORTEM fill:#eef2ff,stroke:#4f46e5,stroke-width:2px
