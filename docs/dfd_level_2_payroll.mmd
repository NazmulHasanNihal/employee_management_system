flowchart TD
    %% Level 2 Data Flow Diagram for 3.0 Payroll & Finance
    
    E_HR[HR Manager]
    E_BANK[Bank/Gateway]

    %% Sub-Processes
    P3_1((3.1 Calculate Taxes))
    P3_2((3.2 Process Gross to Net))
    P3_3((3.3 Generate PDF Payslip))
    P3_4((3.4 Commit Event Ledger))

    %% Data Stores
    D1[(D1: User DB)]
    D2[(D2: HR DB)]
    D3_P[(D3a: Payroll DB)]
    D3_E[(D3b: EventStore DB)]

    %% Flows
    E_HR -->|Initiate Monthly Payroll| P3_2
    
    P3_2 -->|Fetch Base Salary| D1
    P3_2 -->|Fetch LOP/Overtime| D2
    
    P3_2 -->|Gross Amount| P3_1
    D1 -->|Fetch Tax Profile| P3_1
    P3_1 -->|Tax Deductions| P3_2
    
    P3_2 -->|Store Final Payroll| D3_P
    
    P3_2 -->|Triggers Document Prep| P3_3
    P3_3 -->|Request Payroll Data| D3_P
    P3_3 -->|Save PDF File| D3_P
    
    P3_2 -->|Financial State Change| P3_4
    P3_4 -->|Append Ledger Hash| D3_E
    
    P3_4 -->|Disbursement Batch| E_BANK
