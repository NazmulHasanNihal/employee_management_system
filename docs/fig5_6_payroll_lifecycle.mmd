stateDiagram-v2
    %% Figure 5.6 — Payroll Lifecycle
    
    [*] --> DRAFT : HR initializes month's payroll
    
    state DRAFT {
        [*] --> ComputeEarnings : Retrieve Base Salary & Overtime
        ComputeEarnings --> ComputeDeductions : Apply PF, Late Penalties
        ComputeDeductions --> ComputeTax : Calculate Tax Slabs
        ComputeTax --> Review : Awaiting HR verification
    }
    
    DRAFT --> PROCESSED : HR approves & commits to ledger
    
    state PROCESSED {
        [*] --> RecordStatutory : Save PF & Gratuity snapshots
        RecordStatutory --> CreatePayments : Generate bKash/Bank records
    }
    
    PROCESSED --> DISBURSED : Payment Gateway confirms transfer
    DISBURSED --> [*]
    
    note right of PROCESSED
        Emits PAYROLL_PROCESSED event
        to Immutable Event Store
    end note
