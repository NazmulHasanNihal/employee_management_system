# ── Database (Supabase / Postgres) ──
DATABASE_URL="postgresql://user:pass@host:5432/postgres?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/postgres?sslmode=require"

# ── Supabase Auth ──
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"
NEXT_SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# ── App ──
# Email granted immutable system-owner (CEO) privileges. Keep this secret; rotate if leaked.
OWNER_EMAIL="admin@example.com"
CRON_SECRET="your-secure-cron-secret-here"

# ── Web Push (VAPID) ── generate with `npx web-push generate-vapid-keys` ──
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# ── Go PDF microservice (services/go-backend) ── REQUIRED when running that service ──
PAYROLL_API_TOKEN="a-long-random-secret"
PAYROLL_CORS_ORIGIN="http://localhost:3000"

# ── Optional observability ──
NEXT_PUBLIC_POSTHOG_KEY=""
# Sentry DSN for error monitoring. error.tsx + global-error.tsx report here.
# REQUIRED for real crash alerts — without it Sentry silently no-ops and errors
# are dropped. Get this from your Sentry project settings (Settings → Projects →
# Client Keys / DSN).
NEXT_PUBLIC_SENTRY_DSN=""
# Sentry org + project slugs (used for source-map upload + release tracking).
# Find them in your Sentry URL: sentry.io/[org]/[project]/.
SENTRY_ORG=""
SENTRY_PROJECT=""
# Sentry auth token (already added to .env). Used by `withSentryConfig` to
# upload source maps at build time.
SENTRY_AUTH_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Real-time attendance presence (PartyKit) ──
# Run `pnpm partykit` to start the presence server (default http://localhost:1999).
# The attendance page live-refreshes manager panels via this host. If unset, the
# client gracefully falls back to localhost:1999 and degrades to manual refresh.
NEXT_PUBLIC_PARTYKIT_HOST="http://localhost:1999"

# ── Employee invitation signing ──
# Secret used to sign invite links. Falls back to the Supabase service-role key.
INVITE_SECRET=""

# ── Admin bootstrap script (scripts/create-real-admin.ts) ──
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="a-strong-password-at-least-8-chars"
ADMIN_NAME="System Owner"
