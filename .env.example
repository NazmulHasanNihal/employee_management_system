# SUPABASE DATABASE CONNECTION
# Go to Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Make sure the "Transaction" mode is selected for DATABASE_URL (Port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Make sure the "Session" mode is selected for DIRECT_URL (Port 5432)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# UPSTASH REDIS (for rate limiting)
UPSTASH_REDIS_REST_URL=https://<upstash-redis-endpoint>
UPSTASH_REDIS_REST_TOKEN=<upstash-redis-token>

# POSTHOG (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=<posthog-project-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# SENTRY (error tracking)
SENTRY_AUTH_TOKEN=<sentry-auth-token>
NEXT_PUBLIC_SENTRY_DSN=<sentry-dsn>
SENTRY_ORG=<sentry-org>
SENTRY_PROJECT=<sentry-project>

# PUBLIC SITE ORIGIN (used for absolute invite links sent by email)
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# WEB PUSH NOTIFICATIONS
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT="mailto:<your-email@example.com>"

# SYSTEM OWNER EMAIL (grants isOwner + CEO privileges)
OWNER_EMAIL="<owner-email@example.com>"

# CRON JOB SECRET
CRON_SECRET="<random-secret-string>"

# NID ENCRYPTION (optional: defaults to a derived key if omitted)
# NID_ENCRYPTION_KEY=<32-byte-base64-key>

# EMAIL PROVIDER (optional: for transactional emails)
# RESEND_API_KEY=<resend-api-key>
# EMAIL_FROM="noreply@yourdomain.com"
